# Vibe Video 环境配置
# 复制此文件为 .env 并填入实际值

# OpenAI API (用于 Whisper 语音识别, 可选 — 默认使用本地 whisper)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 自定义 LLM API (用于视觉分析和剧本生成)
CUSTOM_API_KEY=your-key-here
CUSTOM_BASE_URL=https://your-api-endpoint.com/v1

# 模型配置
VISUAL_MODEL=mimo-v2.5
TEXT_MODEL=mimo-v2.5-pro
WHISPER_MODEL=base
